{
  "name": "proelectrica-control-manager",
  "version": "0.1.0",
  "description": "Aplicacion de escritorio para control de motores y mantenimientos industriales.",
  "main": "src/main/main.js",
  "author": "Proelectrica",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.proelectrica.controlmanager",
    "productName": "Proelectrica Control Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "electron": "^34.5.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
