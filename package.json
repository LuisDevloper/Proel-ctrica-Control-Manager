{
  "name": "proelectrica-control-manager",
  "version": "0.1.4",
  "description": "Aplicacion de escritorio para control de motores y mantenimientos industriales.",
  "main": "src/main/main.js",
  "author": "Proelectrica",
  "license": "MIT",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently -k \"npm run vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:icon": "node scripts/make-icon.mjs",
    "build": "npm run build:icon && npm run build:renderer && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.proelectrica.controlmanager",
    "productName": "Proelectrica Control Manager",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/database/**/*",
      "src/services/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "forceCodeSigning": false,
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "LuisDevloper",
      "repo": "Proel-ctrica-Control-Manager"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^5.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@jimp/core": "^1.6.1",
    "@jimp/js-png": "^1.6.1",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "wait-on": "^9.0.5"
  }
}
