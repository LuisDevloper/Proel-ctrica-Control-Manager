{
  "name": "proelectrica-control-manager",
  "version": "1.9.0",
  "description": "Aplicacion de escritorio para control de motores y mantenimientos industriales.",
  "main": "src/main/main.js",
  "author": "Proelectrica",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisDevloper/Proel-ctrica-Control-Manager.git"
  },
  "scripts": {
    "vite": "vite",
    "dev": "concurrently -k \"npm run vite\" \"npm run electron:wait\"",
    "electron:wait": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "node scripts/export-changelog-manifest.mjs && vite build",
    "build:icon": "node scripts/sync-logo-assets.mjs && node scripts/make-icon.mjs",
    "build:installer-assets": "node scripts/sync-logo-assets.mjs && node scripts/make-installer-assets.mjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run rebuild:native && npm run build:icon && npm run build:installer-assets && npm run build:renderer && electron-builder",
    "release:github": "npm run rebuild:native && npm run build:icon && npm run build:installer-assets && npm run build:renderer && node --use-system-ca ./node_modules/electron-builder/cli.js --publish always",
    "db:init": "node scripts/init-db.mjs",
    "start": "electron .",
    "test": "node --test tests/**/*.test.js",
    "dataverse:template": "node scripts/generate-dataverse-template.mjs"
  },
  "build": {
    "appId": "com.proelectrica.controlmanager",
    "productName": "Proelectrica Control Manager",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/database/**/*",
      "src/database/config.js",
      "src/services/**/*",
      "src/modules/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "forceCodeSigning": false,
    "nsis": {
      "installerIcon": "build/installer-icon.ico",
      "uninstallerIcon": "build/installer-icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "installerHeader": "build/installer-header.bmp",
      "installerLanguages": [
        "es_ES"
      ],
      "shortcutName": "Proélectrica Control Manager",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "LuisDevloper",
      "repo": "Proel-ctrica-Control-Manager",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^5.3.0",
    "exceljs": "^4.4.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^1.14.0",
    "pg": "^8.13.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "semver": "^7.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@jimp/core": "^1.6.1",
    "@jimp/js-png": "^1.6.1",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "wait-on": "^9.0.5"
  }
}
